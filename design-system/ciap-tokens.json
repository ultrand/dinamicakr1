{
  "meta": {
    "name": "CIAP Design System (extraido)",
    "source": "ciap-v136-wizard-refinado.jsx",
    "version": "1.0.0"
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px"
  },
  "radius": {
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px"
  },
  "fontSize": {
    "xs": "11px",
    "sm": "12px",
    "base": "13px",
    "md": "14px",
    "lg": "16px",
    "xl": "18px",
    "2xl": "24px",
    "3xl": "28px"
  },
  "transition": {
    "fast": "0.15s ease",
    "base": "0.2s ease",
    "slow": "0.3s ease",
    "spring": "0.4s cubic-bezier(0.34, 1.56, 0.64, 1)"
  },
  "motion": {
    "durationsSeconds": {
      "instant": 0.15,
      "fast": 0.18,
      "base": 0.2,
      "medium": 0.25,
      "relaxed": 0.3,
      "slow": 0.4,
      "slower": 0.5
    },
    "staggerStep": 0.1,
    "easing": {
      "standard": [0.4, 0, 0.2, 1],
      "emphasized": [0.16, 1, 0.3, 1]
    },
    "spring": {
      "modal": { "type": "spring", "damping": 20, "stiffness": 300 },
      "slidePanel": { "type": "spring", "damping": 25, "stiffness": 200 }
    },
    "framerPresets": [
      "nudgeY",
      "fadeScale",
      "modalSpring",
      "popover",
      "headerLift",
      "fade",
      "innerModal",
      "backdropFade",
      "sheetScale",
      "listSlide",
      "dockChip",
      "microLift",
      "projectGridSection",
      "projectCard",
      "sectionFade",
      "onboardingY12",
      "onboardingY8",
      "onboardingX8",
      "onboardingYN8",
      "fabChecklist",
      "onboardingHero",
      "celebrationCard",
      "celebrationIcon",
      "celebrationBackdrop",
      "celebrationTitle",
      "celebrationBody",
      "celebrationButton",
      "wizardModal",
      "wizardIconPop"
    ],
    "sourceFile": "ciap-motion.ts"
  },
  "theme": {
    "light": {
      "bgPrimary": "#FFFFFF",
      "bgSecondary": "#FAFAFA",
      "bgTertiary": "#F4F4F5",
      "bgElevated": "#FFFFFF",
      "textPrimary": "#18181B",
      "textSecondary": "#71717A",
      "textTertiary": "#A1A1AA",
      "accent": "#7C3AED",
      "accentLight": "#8B5CF6",
      "accentSubtle": "rgba(124, 58, 237, 0.08)",
      "border": "#E4E4E7",
      "borderSubtle": "#F4F4F5",
      "shadowSm": "0 1px 2px rgba(0, 0, 0, 0.04)",
      "shadowMd": "0 4px 12px rgba(0, 0, 0, 0.08)",
      "shadowLg": "0 8px 24px rgba(0, 0, 0, 0.12)",
      "shadowXl": "0 16px 48px rgba(0, 0, 0, 0.16)",
      "overlay": "rgba(0, 0, 0, 0.4)"
    },
    "dark": {
      "bgPrimary": "#09090B",
      "bgSecondary": "#18181B",
      "bgTertiary": "#27272A",
      "bgElevated": "#1F1F23",
      "textPrimary": "#FAFAFA",
      "textSecondary": "#A1A1AA",
      "textTertiary": "#71717A",
      "accent": "#8B5CF6",
      "accentLight": "#A78BFA",
      "accentSubtle": "rgba(139, 92, 246, 0.15)",
      "border": "#27272A",
      "borderSubtle": "#1F1F23",
      "shadowSm": "0 1px 2px rgba(0, 0, 0, 0.2)",
      "shadowMd": "0 4px 12px rgba(0, 0, 0, 0.3)",
      "shadowLg": "0 8px 24px rgba(0, 0, 0, 0.4)",
      "shadowXl": "0 16px 48px rgba(0, 0, 0, 0.5)",
      "overlay": "rgba(0, 0, 0, 0.7)"
    }
  },
  "semantic": {
    "status": {
      "executing": "#6B46C1",
      "paused": "#F59E0B",
      "completed": "#10B981",
      "postponed": "#8B5CF6",
      "dismissed": "#6B7280",
