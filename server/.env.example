# PostgreSQL (local: docker compose up db — ver raiz do projeto)
DATABASE_URL="postgresql://dinamica:dinamica@localhost:5432/dinamica"
# Mesmo valor em dev local. Na Vercel + Supabase: Session pooler :5432 (host ...pooler.supabase.com). Ver VERCEL-SOLO.md.
DIRECT_URL="postgresql://dinamica:dinamica@localhost:5432/dinamica"

# Token do painel /admin (troque em produção)
ADMIN_TOKEN="defina-um-token-longo-e-secreto"

PORT=3001

# URL pública do serviço (opcional — só logs)
PUBLIC_URL="http://localhost:3001"

# Origens permitidas no CORS, separadas por vírgula. Vazio ou * = qualquer origem.
# Ex.: https://meu-app.vercel.app,https://www.meudominio.com
CORS_ORIGINS="http://localhost:5173,http://localhost:3001"
