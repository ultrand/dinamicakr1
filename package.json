{
  "name": "dinamica-kr1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "postinstall": "npm run db:generate --workspace=server",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "vercel-build": "node scripts/vercel-build.mjs",
    "db:push": "npm run db:push --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "start": "npm run start --workspace=server",
    "start:seed": "npm run start:seed --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
